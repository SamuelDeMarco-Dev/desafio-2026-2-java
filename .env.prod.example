# ============================================================================
# Variáveis de PRODUÇÃO (VPS). Copie para ".env" na raiz do projeto na VPS:
#     cp .env.prod.example .env
# e preencha os valores reais. O docker-compose.prod.yml lê este ".env".
# NUNCA versione o ".env" preenchido (ele já está no .gitignore).
# ============================================================================

# --- Domínio e HTTPS ---------------------------------------------------------
# DOMAIN: apenas o host (sem https://). É o endereço que o Caddy protege com TLS.
DOMAIN=seudominio.com
# PUBLIC_URL: URL completa do site. Usada no build do frontend (VITE_API_URL) e
# na lista de CORS. Deve ser https:// + o mesmo domínio acima.
PUBLIC_URL=https://seudominio.com
# E-mail usado pelo Let's Encrypt para avisos de expiração de certificado.
ACME_EMAIL=voce@email.com

# --- Banco de dados ----------------------------------------------------------
DB_NAME=documentos_academicos
DB_USERNAME=documentos_app
DB_PASSWORD=defina_uma_senha_forte_para_o_banco

# --- Administrador inicial (criado no primeiro startup) ----------------------
ADMIN_LOGIN=administrador
ADMIN_PASSWORD=defina_uma_senha_forte_para_o_admin
ADMIN_CODIGO_RESPONSAVEL=1000

# --- JWT ---------------------------------------------------------------------
# Gere um segredo forte (>= 32 caracteres) na VPS com:
#     openssl rand -base64 48
JWT_SECRET=troque_por_uma_chave_secreta_de_no_minimo_32_caracteres
JWT_EXPIRACAO_SEGUNDOS=3600