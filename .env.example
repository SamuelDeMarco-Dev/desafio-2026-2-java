# Perfil da aplicação
SPRING_PROFILES_ACTIVE=dev

# Banco de dados
DB_NAME=documentos_academicos
DB_USERNAME=documentos_app
DB_PASSWORD=substitua_pela_sua_senha

# Execução local sem Docker
DB_URL=jdbc:postgresql://localhost:5432/documentos_academicos

# Portas expostas pelo Docker
SERVER_PORT=8080
DB_PORT=5433

# Administrador inicial (criado no primeiro startup)
ADMIN_LOGIN=administrador
ADMIN_PASSWORD=defina_uma_senha_forte
ADMIN_CODIGO_RESPONSAVEL=1000

# JWT (mínimo 32 caracteres — exigência do HS256)
JWT_SECRET=troque-por-uma-chave-secreta-de-no-minimo-32-caracteres
JWT_EXPIRACAO_SEGUNDOS=3600